# =============================================================
# Taka Bachai - Sample env file for the prod (Supabase) profile
#
# Copy this file to `.env` and fill in your real credentials.
# `.env` is gitignored, this template is safe to commit.
# Run with:  ./run-prod.sh
# =============================================================

SPRING_PROFILES_ACTIVE=prod

# --- Supabase Session Pooler (Supavisor) ---
# Find this string in:
#   Supabase Dashboard -> Project Settings -> Database
#     -> Connection string -> "Session pooler" tab
#
# JDBC form (note the "jdbc:" prefix and "?sslmode=require"):
#   jdbc:postgresql://aws-<n>-<region>.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_JDBC_URL=jdbc:postgresql://aws-<n>-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Username for the pooler is "postgres.<your-project-ref>"
SUPABASE_DB_USER=postgres.<your-project-ref>

# Database password (Project Settings -> Database -> Reset database password)
SUPABASE_DB_PASSWORD=<your-db-password>

# Schema/seed data is already loaded in Supabase, leave as "never".
# Set to "always" only for a one-time bootstrap on a fresh project.
SPRING_SQL_INIT_MODE=never
